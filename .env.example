# Langfuse Observability Credentials
LANGFUSE_HOST="http://localhost:3000"
LANGFUSE_SECRET_KEY="your-langfuse-secret-key"
LANGFUSE_PUBLIC_KEY="your-langfuse-public-key"
LANGFUSE_BASE_URL="http://localhost:3000"

# Local Unsloth LLM Server Configuration
UNSLOTH_BASE_URL="http://127.0.0.1:8888/v1"
UNSLOTH_API_KEY="sk-unsloth-YOUR_KEY"
LLM_MODEL="unsloth/Qwen3.6-27B-MTP-GGUF:UD-Q4_K_XL"

# Bluesky API Credentials
BSKY_HANDLE="your-handle.bsky.social"
BSKY_APP_PASSWORD="your-app-password"

# Docker Container Overrides (automatically mapped via docker-compose)
# UNSLOTH_BASE_URL_DOCKER="http://host.docker.internal:8888/v1"
# LANGFUSE_HOST_DOCKER="http://host.docker.internal:3000"


